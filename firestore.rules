rules_version = '2';

// Firestore security rules for RISE progress backup.
//
// Client-side account namespacing (src/lib/storage.js) is NOT a security
// boundary — it only separates accounts within one browser. These rules are
// the boundary Firestore enforces itself, independent of any client:
//
//   - Ownership is derived ONLY from request.auth.uid and the {userId} path
//     segment. A uid/email/name embedded in the document payload is never
//     trusted or consulted, so a client cannot grant itself access by
//     spoofing an ownership field or by changing the path to another uid.
//   - Unauthenticated requests can neither read nor write learner progress.
//   - The only supported collection is each learner's own progress backup;
//     everything else is denied by default.
//
// Firestore is the only Firebase data product in use (no Realtime Database,
// no Cloud Storage): all other paths stay denied, with no permissive
// placeholder rule. Deploy with `firebase deploy --only firestore:rules`
// (config in firebase.json); tests live in tests/rules/. See
// docs/system/AUTH_SETUP.md.
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // A learner may read/write only their own progress document(s):
    //   users/{uid}/progress/{docId}   (currently a single doc: .../progress/main)
    match /users/{userId}/progress/{docId} {
      allow read, write: if isOwner(userId);
    }

    // Deny access everywhere else — including any other subcollection under
    // users/{userId} — so the supported path above is the only way in.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
