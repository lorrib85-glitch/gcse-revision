rules_version = '2';

// Firestore security rules for RISE progress backup.
// Firebase Hosting/CLI are not used in this repo — paste these into
// Firebase Console > Firestore Database > Rules and Publish.
// See docs/system/AUTH_SETUP.md.
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user may read/write only their own progress document(s).
    match /users/{userId}/progress/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Everything else is denied by default (no match = no access), stated
    // explicitly here for clarity.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
