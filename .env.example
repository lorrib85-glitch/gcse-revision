# Copy to .env.local for local dev (never commit .env.local — it's gitignored).
# Values come from Firebase Console > Project settings > General > Your apps > Web app.
# None of these are secret (Firebase web config is safe to expose client-side),
# but they still live in env vars rather than source so per-environment
# (dev/preview/prod) Firebase projects can differ without code changes.
#
# Without these set, Google sign-in is disabled and the app falls back to the
# existing guest name-entry flow — it never crashes on a missing config.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Existing — required for /api/recall, /api/grade, /api/examiner, /api/gradetest,
# /api/guidedExamResponse, /api/examRoundDebrief. Server-side only, never exposed
# to the client — do not prefix with VITE_.
ANTHROPIC_API_KEY=
